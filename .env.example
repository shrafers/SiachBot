# Telegram API credentials — get from https://my.telegram.org
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# Your Telegram phone number (international format, e.g. +972501234567)
TG_PHONE=+your_phone_number

# Numeric group ID — run list_groups.py to find it
TG_GROUP_ID=your_group_id_here

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

DATABASE_URL= your_database_url_here

R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=siachbot-audio

TELEGRAM_BOT_TOKEN=your_bot_token
ADMIN_CHAT_ID=your_telegram_user_id

# Local Bot API Server — removes the 20MB file download limit
# Same values as TG_API_ID / TG_API_HASH above, just under these names for the Docker container
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Set this in production (points to the local server); omit for local dev
TELEGRAM_LOCAL_SERVER=http://telegram-bot-api:8081